{
  "applicationId": "com.galago.calculator",
  "version": "1.0.0",
  "defaultMode": "window",
  "port": 0,
  "documentRoot": "/dist/",
  "url": "/",
  "enableServer": true,
  "enableNativeAPI": true,
  "tokenSecurity": "one-time",
  "logging": {
    "enabled": false
  },
  "nativeAllowList": [
    "app.*",
    "os.*",
    "window.*"
  ],
  "modes": {
    "window": {
      "title": "Calculator-NG",
      "width": 400,
      "height": 600,
      "minWidth": 400,
      "minHeight": 600,
      "resizable": false,
      "center": true,
      "maximize": false,
      "exitProcessOnClose": true
    }
  },
  "cli": {
    "binaryName": "Calculator-NG",
    "applicationName": "Calculator-NG",
    "applicationIcon": "dist/icon.png",
    "resourcesPath": "/dist/",
    "distributionPath": "/output/",
    "deploymentPatterns": ["dist/**"]
  }
}
